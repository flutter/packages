RouteBase get $hasNotOverriddenOnExitRoute => GoRouteData.$route(
      path: '/has-not-overridden-on-exit-route',
      factory: $HasNotOverriddenOnExitRoute._fromState,
    );

mixin $HasNotOverriddenOnExitRoute on GoRouteData {
  static HasNotOverriddenOnExitRoute _fromState(GoRouterState state) =>
      HasNotOverriddenOnExitRoute();

  @override
  String get location => GoRouteData.$location(
        '/has-not-overridden-on-exit-route',
      );

  @override
  void go(BuildContext context) => context.go(location);

  @override
  Future<T?> push<T>(BuildContext context) => context.push<T>(location);

  @override
  void pushReplacement(BuildContext context) =>
      context.pushReplacement(location);

  @override
  void replace(BuildContext context) => context.replace(location);
}
