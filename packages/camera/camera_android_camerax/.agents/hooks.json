{
  "dart-format": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "command": "./.agents/hooks/dart_format.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "dart-analyze-gate": {
    "Stop": [
      {
        "type": "command",
        "command": "./.agents/hooks/dart_analyze.sh",
        "timeout": 90
      }
    ]
  }
}
